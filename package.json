{
  "name": "@inaumanmajeed/skeletonify",
  "version": "0.2.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Zero-config React skeleton wrapper with L1 heuristic + L2 learning engine. Drop it in, get a plausible loading skeleton for any subtree — SSR-safe, zero flicker.",
  "license": "MIT",
  "author": "inaumanmajeed",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inaumanmajeed/Skeletonify.git"
  },
  "bugs": {
    "url": "https://github.com/inaumanmajeed/Skeletonify/issues"
  },
  "homepage": "https://github.com/inaumanmajeed/Skeletonify#readme",
  "keywords": [
    "react",
    "skeleton",
    "loading",
    "placeholder",
    "shimmer",
    "nextjs",
    "tailwind",
    "ssr",
    "suspense"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:dev": "vite demo",
    "demo:build": "vite build demo",
    "demo:preview": "vite preview demo",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.8",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
